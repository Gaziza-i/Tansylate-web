server {
    listen 80;
    server_name tansylate.ru www.tansylate.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name tansylate.ru www.tansylate.ru;

    # ssl_certificate     /etc/letsencrypt/live/tansylate.ru/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/tansylate.ru/privkey.pem;

    # ВАЖНО: увеличить лимит для загрузки фото (дефолт 1MB — слишком мало)
    client_max_body_size 25m;

    # Статика загруженных фото — отдаём напрямую через Nginx (быстрее)
    location /uploads/ {
        alias /var/www/tansylate/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Все API-запросы проксируем в Node.js
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Для загрузки файлов — отключить буферизацию и увеличить таймауты
        proxy_request_buffering off;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
        client_max_body_size 25m;
    }

    # Всё остальное — SPA
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
